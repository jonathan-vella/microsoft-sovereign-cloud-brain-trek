---
/**
 * KnowledgeCheck.astro
 *
 * Collapsible "Click to reveal answer" block used in the level-NN knowledge
 * checks. Replaces the Jekyll/kramdown pattern:
 *
 *   <details markdown="1">
 *   <summary>Click to reveal answer</summary>
 *
 *   **Correct Answer: B**
 *   ...
 *   </details>
 *
 * The answer body is provided as MDX children (NOT a prop string), so it
 * can contain code blocks, links, lists, callouts, and diagrams without
 * any escaping. Use it in .mdx files like:
 *
 *   <KnowledgeCheck answer="B" reference="../level-100/topic.md">
 *     **Explanation:** Detailed reasoning here. Other options are wrong
 *     because ...
 *   </KnowledgeCheck>
 *
 * Props:
 *   answer    — short identifier ("B", "True", "All of the above").
 *   reference — optional internal or external link to follow up.
 *   summary   — override the default "Click to reveal answer" label.
 */
interface Props {
  answer: string;
  reference?: string;
  summary?: string;
}

const { answer, reference, summary = "Click to reveal answer" } = Astro.props;
---

<details class="knowledge-check">
  <summary>{summary}</summary>
  <p><strong>Correct Answer: {answer}</strong></p>
  <slot />
  {
    reference && (
      <p class="knowledge-check__reference">
        <strong>Reference:</strong> <a href={reference}>{reference}</a>
      </p>
    )
  }
</details>

<style>
  .knowledge-check__reference {
    margin-top: 0.75rem;
    font-size: 0.95em;
  }
</style>
