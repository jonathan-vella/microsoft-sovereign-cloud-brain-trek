# Ignore system files
.DS_Store
Thumbs.db

# Ignore editor files
.vscode/*
!.vscode/mcp.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Ignore build output
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/

# Ignore Ruby/Bundler files
vendor/
Gemfile.lock
.bundle/

# Ignore node modules if using any npm packages
node_modules/
package-lock.json
# The Astro site (site/) needs its lockfile checked in for reproducible
# installs across CI and contributors. The root rule above stays for the
# Jekyll project root.
!site/package-lock.json

# Ignore temporary files
*.tmp
*.temp
*.log

# Ignore backup files created by scripts
*.backup.*

# Ignore personal notes
notes/
scratch/
docs/level-50/plan.md
