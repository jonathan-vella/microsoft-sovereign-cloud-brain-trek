{
    "name": "Sovereign Cloud Brain Trek",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",

    // Phase 6 cutover — switched from the Jekyll dev container image to a
    // Node 20 image because the Astro Starlight build is the production
    // path. Python is still available as a feature for ad-hoc scripts.
    "features": {
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.12"
        }
    },

    // Configure tool-specific properties.
    "customizations": {
        "vscode": {
            "extensions": [
                "astro-build.astro-vscode",
                "DavidAnson.vscode-markdownlint",
                "yzhang.markdown-all-in-one",
                "bierner.markdown-mermaid",
                "redhat.vscode-yaml",
                "EditorConfig.EditorConfig",
                "esbenp.prettier-vscode"
            ],
            "settings": {
                "markdownlint.config": {
                    "extends": "${workspaceFolder}/.markdownlint.json"
                },
                "markdownlint.run": "onSave"
            }
        }
    },

    // Astro dev/preview server defaults to 4321.
    "forwardPorts": [4321],

    // Install site dependencies and pre-commit hooks on first create.
    "postCreateCommand": "npm ci --prefix site && pre-commit install"
}
